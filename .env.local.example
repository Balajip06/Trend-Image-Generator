# =====================================================================
# Trend Image Generator — env template
# Copy to `.env.local` and fill values. Never commit `.env.local`.
# =====================================================================

# ---- App ----
NEXT_PUBLIC_SITE_URL=https://trendly-cyan.vercel.app
ANONYMOUS_DAILY_BUDGET_USD=20

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google Gemini (Nano Banana / Pro) ----
GEMINI_API_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Credit-pack Stripe price IDs (create one product per pack, one price each)
STRIPE_PRICE_ID_SMALL=
STRIPE_PRICE_ID_MEDIUM=
STRIPE_PRICE_ID_LARGE=

# ---- Resend (transactional email + push fallback) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Web Push (VAPID) ----
# Generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---- Cloudflare Turnstile (anti-bot) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- PostHog (product analytics) ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- Sentry (errors + perf) ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---- Upstash Redis (rate limit + abuse budget counter) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Phase 6 (auto trend detector, post-MVP) ----
# Leave blank for MVP — sources return [] and orchestrator skips them.
TIKTOK_CREATIVE_CENTER_KEY=
INSTAGRAM_SESSION_COOKIE=
REDDIT_USER_AGENT=TrendImageGenerator/0.1

# ---- Dev-only flags ----
# Set to 'true' to short-circuit Supabase reads with in-memory fixtures (lib/dev/mock-data.ts).
# Never set in production.
MOCK_TRENDS=
