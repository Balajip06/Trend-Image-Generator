# =====================================================================
# Trend Image Generator — env template
# Copy to `.env.local` and fill values. Never commit `.env.local`.
# =====================================================================

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ANONYMOUS_DAILY_BUDGET_USD=20

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google Gemini (Nano Banana / Pro) ----
GEMINI_API_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Resend (transactional email + push fallback) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Web Push (VAPID) ----
# Generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---- Cloudflare Turnstile (anti-bot) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- PostHog (product analytics) ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- Sentry (errors + perf) ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---- Upstash Redis (rate limit + abuse budget counter) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
