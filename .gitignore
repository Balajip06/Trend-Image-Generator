# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/playwright/.cache
/e2e/screenshots
/.playwright-mcp/
/terms-page-verify.png
*-verify.png
# Ad-hoc manual QA screenshots dropped at repo root during dev sessions
/*.jpeg
/*.jpg
/*.png

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (template only — never commit real secrets)
.env*
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase
/supabase/.branches
/supabase/.temp
/supabase/.env

# Graphify tooling cache (local-only knowledge graph)
graphify-out/

# Sentry
.sentryclirc
.sentry-build-plugin

# IDE
.idea
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Scratch
.claude/draft/
.claude/worktrees/

.vercel
.env*

# E2E status report — generated artifacts (regenerate: node scripts/build-status-report.mjs)
e2e/status/shots/
e2e/status/results/
e2e/status/report.html
